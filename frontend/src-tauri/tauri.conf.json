{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maintenance Inventory Tracker 3.0",
  "version": "3.0.0-rc.1",
  "identifier": "com.jbtusa.maintenanceinventorytracker3.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:maintenance_inventory_3.db"
      ]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Maintenance Inventory Tracker 3.0",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "maximized": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon-16x16.png",
      "icons/icon-24x24.png",
      "icons/icon-32x32.png",
      "icons/icon-48x48.png",
      "icons/icon-64x64.png",
      "icons/icon-128x128.png",
      "icons/icon-256x256.png",
      "icons/icon-512x512.png",
      "icons/icon-1024x1024.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
