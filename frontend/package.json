{
  "name": "maintenance-inventory-tracker",
  "private": true,
  "version": "3.0.0-rc.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "inspect:requisition": "node scripts/inspect-requisition-template.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "version:patch": "node scripts/bump-version.mjs",
    "version:bump": "npm run version:patch",
    "release:patch": "npm run release:build",
    "release:build": "npm run version:patch && npm run release:build:no-bump",
    "release:build:no-bump": "powershell -ExecutionPolicy Bypass -File scripts/build-release.ps1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "pdf-lib": "^1.17.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx-populate": "^1.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^24.12.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10"
  }
}
